# Google Analytics (Optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# === Supabase ===
# Get these from your Supabase project: Settings -> API
# For local development: run `npx supabase start` and use the local values
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Admin API (server-side only) — get from Supabase project: Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=

# === Database (Drizzle ORM) ===
# For local development: default connects to Supabase local PostgreSQL
# POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# POSTGRES_URL_NON_POOLING=  # Direct connection for drizzle-kit (production)
