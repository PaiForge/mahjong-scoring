# NOTE: Do not add comments to the actual .env file.
# Supabase CLI's env() parser may fail to resolve variables if comments are present.
# Google OAuth for Supabase Auth (referenced by config.toml via env())
# Get credentials from Google Cloud Console: https://console.cloud.google.com/apis/credentials
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=<your-google-client-id>
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=<your-google-client-secret>
